{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2017"],
    "outDir": "./dist",
    "rootDir": "./",
    // "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "app.ts",
    "config/**/*",
    "models/**/*",
    "controllers/**/*",
    "routes/**/*",
    "middlewares/**/*",
    "services/**/*",
    "utils/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
