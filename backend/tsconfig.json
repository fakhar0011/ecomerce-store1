{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    // "moduleResolution": "bundler",
    "lib": ["ES2017"],
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "app.ts",
    "config/**/*",
    "models/**/*",
    "graphql/**/*",
    "routes/**/*",
    "controllers/**/*",
    "middlewares/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
