{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "moduleResolution": "bundler", // ✅ bundler use karo
    "lib": ["ES2017"],
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["app.ts", "config/**/*", "models/**/*", "graphql/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "controllers",
    "middlewares",
    "routes",
    "socket.ts"
  ]
}
